{
  "name": "notes-static",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "init-content": "node scripts/init-content.mjs",
    "predev": "node scripts/init-content.mjs",
    "prebuild": "node scripts/init-content.mjs",
    "dev": "next dev",
    "build": "NODE_ENV=production next build",
    "build:static": "NODE_ENV=production NEXT_EXPORT=true next build",
    "start": "next start",
    "preview": "npm run build:static && npx serve out",
    "lint": "eslint",
    "audit:prod": "npm audit --omit=dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "watch": "node --env-file=.env scripts/watch-inbox.mjs",
    "ingest": "node --env-file=.env scripts/watch-inbox.mjs --once"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "fuse.js": "^7.3.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.94.0",
    "@google/genai": "^1.52.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "chokidar": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.1.1",
    "openai": "^6.36.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
